  \tikzstyle{block} = [rectangle, draw, fill=blue!10, text width=4cm, text centered, rounded corners, minimum height=1cm]
  \tikzstyle{arrow} = [->, thick]

  \node [block] (input) {OSM Road Network};
  \node [block, below of=input] (encoder) {RRNCO Encoder\\ANE + NAB + AAFM};
  \node [block, below of=encoder] (context) {CCL Context\\RGCR + TSNR};
  \node [block, below of=context] (decoder) {RouteFinder Decoder\\Multi-Depot + Vehicle State};
  \node [block, below of=decoder] (reward) {Humanitarian Reward\\Eq.~\ref{eq:reward}};
  \node [block, right of=context, xshift=3cm] (env) {Disaster MDVRPTW\\Environment};
  \node [block, right of=decoder, xshift=3cm] (train) {POMO + REINFORCE\\Training};

  \draw [arrow] (input) -- (encoder);
  \draw [arrow] (encoder) -- (context);
  \draw [arrow] (context) -- (decoder);
  \draw [arrow] (decoder) -- (reward);
  \draw [arrow] (env) -- (context);
  \draw [arrow] (env) -- (decoder);
  \draw [arrow] (reward) -- (train);
  \draw [arrow] (train) -- (decoder);
\end{tikzpicture}
\caption{DANA architecture showing the four components and their interactions.
  OSM road network data flows through the encoder and context modules to the
  decoder, which produces routes evaluated by the humanitarian reward function.
  POMO training updates the policy via REINFORCE.}
\label{fig:architecture}
\end{figure}

\subsection{Encoder}

The encoder transforms OSM road network coordinates and asymmetric distance
matrices into node embeddings. Following RRNCO~\cite{rrnco2026}, it uses three
key mechanisms:

\textbf{Contextual Gating}: Distance-aware bias injection that incorporates
edge features (distance, duration) into node representations. For each node
$i$, the gate computes:

\begin{equation}
g_i = \sigma(W_g [h_i^{(0)}; \text{AGG}_{j \in \mathcal{N}(i)} e_{ij}])
\end{equation}

where $h_i^{(0)}$ is the initial node embedding, $e_{ij}$ are edge features,
and AGG is a pooling operation.

\textbf{Neural Adaptive Bias (NAB)}: Learnable attention modulation that
adapts self-attention scores based on edge-specific features, enabling the
model to account for asymmetric road network distances:

\begin{equation}
\text{Attention}(Q, K, V) = \text{softmax}\left(\frac{QK^\top}{\sqrt{d_k}} + B_{\text{NAB}}\right) V
\end{equation}

\textbf{Adaptive Attention Fusion (AAFM)}: Multi-head self-attention with
learned fusion weights that combine information across attention heads,
producing enriched node embeddings $h_i \in \mathbb{R}^{d}$.

\subsection{Dynamic Context}

The context module handles disaster events through two sub-modules:

\textbf{RGCR (Relational Graph Context Refiner)}: Updates node embeddings when
disaster events occur. For road closure $(i,j)$, the edge embedding $e_{ij}$
is set to a learned mask token and the affected node representations are
updated through a graph message-passing step:

\begin{equation}
h_i' = h_i + \text{MLP}\left(\sum_{j \in \mathcal{N}(i)} \alpha_{ij} \cdot [h_j; e_{ij}']\right)
\end{equation}

\textbf{TSNR (Temporal Step-wise Network Refiner)}: Maintains a step-wise
hidden state that captures the sequential nature of route construction. At each
decoding step $t$, it computes:

\begin{equation}
s_t = \text{GRU}(s_{t-1}, [h_{v_t}; \text{vehicle\_state}_t])
\end{equation}

where $v_t$ is the last visited node and $\text{vehicle\_state}_t$ encodes
remaining capacity, current time, and elapsed fraction of the planning horizon.

\subsection{Decoder}

The decoder autoregressively constructs routes following a multi-depot
formulation inspired by RouteFinder~\cite{routefinder2024} and
DeepMDV~\cite{deepmdv2025}. At each step, it selects the next customer using
attention over encoded node embeddings and context.

\textbf{Multi-Head Attention Pooling}: The decoder first computes a fixed-size
context vector from the encoder outputs using multi-head attention pooling,
with the depot embedding as query:

\begin{equation}
c = \text{MHA}(\text{depot\_embedding}, \{h_i\}, \{h_i\})
\end{equation}

\textbf{Vehicle State Encoding}: We maintain a rich vehicle state vector
$\phi \in \mathbb{R}^{d}$ encoding:

\begin{equation}
\phi = \text{MLP}\left(\left[\frac{v}{V}; \frac{t}{T}; \frac{c_{\text{rem}}}{c_{\text{max}}}; \frac{u}{N}\right]\right)
\end{equation}

where $v/V$ is the fraction of vehicles used, $t/T$ is time progress,
$c_{\text{rem}}/c_{\text{max}}$ is remaining capacity ratio, and $u/N$ is
unvisited customer ratio. This state is injected into the decoder context
before computing compatibility scores.

\textbf{Decoder Layer}: Each decoder layer applies Pre-LayerNorm, multi-head
attention, and feedforward sub-layers with residual connections:

\begin{align}
\hat{c} &= \text{LN}(c) \\
c' &= c + \text{MHA}(\hat{c}, \{h_i + e_{ij}\}, \{h_i + e_{ij}\}) \\
c'' &= c' + \text{FFN}(\text{LN}(c'))
\end{align}

Using Pre-LayerNorm (normalize before sub-layers, not after) provides more
stable gradient flow during training, which is critical when stacking multiple
decoder layers.

\textbf{Logit Computation}: The final compatibility scores use a learnable
temperature and clipping parameter:

\begin{equation}
\text{logit}_i = \text{logit\_clip} \cdot \tanh\left(\frac{q^\top k_i}{\text{logit\_temperature}}\right)
\end{equation}

where $q$ is the decoder query, $k_i$ are key embeddings for each customer,
and both \texttt{logit\_clip} and \texttt{logit\_temperature} are learned
during training. This replaces the standard hard-coded $10 \cdot \tanh(\cdot)$
and allows the model to dynamically adjust the exploration-exploitation trade-off.

\textbf{Multi-Depot Handling}: The decoder explicitly accounts for per-start
depot assignments. Each vehicle's route begins at its assigned depot and must
return there. During decoding, the depot embedding is concatenated with the
vehicle state to modulate attention, ensuring depot-aware route construction.

\section{Training}

\subsection{POMO with REINFORCE}

We train DANA using Policy Optimization with Multiple Optima
(POMO)~\cite{pomo2020}. For each instance, POMO generates $N$ trajectories by
starting from $N$ different initial nodes (or depot-customer pairs in the
MDVRPTW case). The REINFORCE gradient estimator with shared baseline is:

\begin{equation}
\nabla_\theta J(\theta) = \frac{1}{N} \sum_{i=1}^N \left(R_i - \bar{R}\right) \nabla_\theta \log \pi_\theta(\tau_i)
\end{equation}

where $\bar{R} = \frac{1}{N} \sum_{i=1}^N R_i$ is the average reward across
all trajectories for the instance. This shared baseline reduces gradient
variance significantly compared to a single-trajectory REINFORCE.

\subsection{Humanitarian Reward Training}

The reward function (Eq.~\ref{eq:reward}) is computed after each complete
episode. The four terms are normalized across the batch to ensure stable
gradients. We use $\alpha = \beta = \gamma = 1$ and $\delta = 0.5$ as default
weights, balancing humanitarian objectives against feasibility constraints.

During training, we apply masking to prevent invalid actions (visiting already
served customers, exceeding vehicle capacity, violating time windows). The
decoder outputs a probability distribution over feasible next customers, and
actions are sampled during training and greedily selected during evaluation.

\subsection{Implementation}

DANA is implemented in pure PyTorch (no RL4CO, no external RL frameworks) for
full control over the architecture and training loop. Key training parameters
are summarized in Table~\ref{tab:training}.

\begin{table}[ht]
\centering
\begin{tabular}{lr}
\toprule
Parameter & Value \\
\midrule
Embedding dimension & 128 \\
Encoder layers & 12 \\
Decoder layers & 3 \\
Feedforward dimension & 512 \\
Number of heads & 8 \\
Learning rate & $1 \times 10^{-4}$ \\
Batch size & 256 \\
Epochs & 100 \\
Instances per epoch & 800 \\
Optimizer & Adam \\
\bottomrule
\end{tabular}
\caption{Training hyperparameters for DANA.}
\label{tab:training}
\end{table}

\subsection{Data Pipeline}

We train on the RRNCO OSM dataset~\cite{rrnco2026}, which provides real-world
asymmetric distance and duration matrices for 100 cities worldwide. We use 80
cities for training and 20 for testing. Per instance, we subsample 50 locations
(depots and customers) with routing context from the OSM road network.

To maximize data diversity, we implement a CityRotation schedule that cycles
through training cities deterministically across epochs, ensuring each epoch
sees a different subset of city data. This prevents overfitting to specific
urban layouts and improves generalization to unseen city geometries.

\section{Experimental Setup}

\subsection{Benchmarks}

We evaluate DANA on six benchmarks following the Guidelines
methodology~\cite{guidelines2021}:

\begin{enumerate}
  \item \textbf{Cordeau MDVRPTW}: 28 instances with 48--288 customers, 2--4
    depots, standard MDVRPTW constraints.
  \item \textbf{Solomon VRPTW}: 56 instances with 100 customers, single depot,
    clustered/random/hybrid distributions.
  \item \textbf{Gehring \& Homberger VRPTW}: Large-scale instances with up to
    1000 customers.
  \item \textbf{X instances (CVRPLIB)}: 30 capacitated VRP instances.
  \item \textbf{RRNCO 100-city OSM}: Real-world asymmetric routing with 50
    locations per city.
  \item \textbf{Cairo/Nile Delta Disaster}: Custom benchmark with synthetic
    disaster events (road closures, demand surges, depot damage) superimposed
    on OSM road networks.
\end{enumerate}

\subsection{Baselines}

We compare DANA against four state-of-the-art solvers:

\begin{itemize}
  \item \textbf{HGS}~\cite{hgs2021}: Hybrid Genetic Search, the leading
    metaheuristic for CVRP.
  \item \textbf{LKH-3}~\cite{neuralkh2021}: Lin-Kernighan-Helsgaun heuristic
    with deep learning enhancements.
  \item \textbf{PyVRP}: Open-source VRP solver with state-of-the-art
    performance on standard benchmarks.
  \item \textbf{OR-Tools}: Google's operations research toolkit with
    CP-SAT and greedy search.
\end{itemize}

\subsection{Evaluation Protocol}

Following the Guidelines methodology:

\begin{itemize}
  \item \textbf{Statistical tests}: Wilcoxon signed-rank test (one-tailed) for
    pairwise algorithm comparison.
  \item \textbf{Multiple comparison correction}: Bonferroni correction with
    target $\alpha = 0.05$.
  \item \textbf{Hardware normalization}: PassMark single-thread score
    normalization for fair time comparisons.
  \item \textbf{Runs}: Each algorithm runs 10 independent trials per instance.
  \item \textbf{Metrics}: Solution quality (humanitarian reward, tour cost),
    computational time, and constraint satisfaction.
\end{itemize}

